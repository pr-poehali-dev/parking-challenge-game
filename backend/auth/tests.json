{
  "tests": [
    {
      "name": "Register new player",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "TestKingXYZ9992", "emoji": "😎", "password": "test1234"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Duplicate nick rejected",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "name": "TestKingXYZ9992", "emoji": "😎", "password": "test1234"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Этот ник уже занят. Выбери другой!"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login correct password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "name": "TestKingXYZ9992", "password": "test1234"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "name": "TestKingXYZ9992", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неверный пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Save Yandex player",
      "method": "POST",
      "path": "/",
      "body": {"action": "save_ya", "yaId": "ya_test999888", "profile": {"name": "ЯИгрок", "emoji": "🚗", "coins": 500, "gems": 0, "xp": 100, "wins": 1, "gamesPlayed": 3, "bestPosition": 2, "selectedCar": 0, "ownedCars": [0], "upgrades": {}}},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Count players",
      "method": "POST",
      "path": "/",
      "body": {"action": "count"},
      "expectedStatus": 200,
      "expectedBody": {"count": 6},
      "bodyMatcher": "partial"
    }
  ]
}